FROM oven/bun:latest

ARG CLIENT_URL
ARG DB_FILE_NAME
ARG BETTER_AUTH_SECRET
ARG BETTER_AUTH_URL

ENV CLIENT_URL=$CLIENT_URL
ENV DB_FILE_NAME=$DB_FILE_NAME
ENV BETTER_AUTH_SECRET=$BETTER_AUTH_SECRET
ENV BETTER_AUTH_URL=$BETTER_AUTH_URL

WORKDIR /server

COPY package*.json .

RUN bun install

COPY . .

EXPOSE 3001

CMD ["bun", "run", "start"]